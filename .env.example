# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Slack bot token (xoxb-...) — needs chat:write scope on #morning-standup
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# --- Gmail OAuth setup ---
# 1. Create a project at https://console.cloud.google.com/
# 2. Enable the Gmail API
# 3. Create OAuth 2.0 credentials (Desktop app type)
# 4. Download as credentials.json and place it in this directory
# 5. Run `python triage.py --auth` once to generate token.json
# credentials.json and token.json must NOT be committed to git
