# Your full Gmail address — threads from this domain are skipped in the briefing
USER_EMAIL=you@yourdomain.com

# Anthropic API key — used to generate summaries and draft replies
ANTHROPIC_API_KEY=sk-ant-...

# Slack Bot Token — needs the chat:write scope and must be invited to #morning-standup
SLACK_BOT_TOKEN=xoxb-...

# Gmail OAuth credentials:
# 1. Create a project at https://console.cloud.google.com
# 2. Enable the Gmail API
# 3. Create an OAuth 2.0 Desktop client and download it as credentials.json
# 4. On first run, a browser window opens for consent; token.json is saved automatically
