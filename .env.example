# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real credentials.

# Your Gmail address. Threads from this domain are skipped in triage.
USER_EMAIL=you@yourdomain.com

# Anthropic API key — used to draft replies and generate summaries.
ANTHROPIC_API_KEY=sk-ant-...

# Slack bot token (needs chat:write scope).
SLACK_BOT_TOKEN=xoxb-...

# Slack channel for the morning briefing (name or channel ID).
SLACK_CHANNEL=#morning-standup

# Paths to Gmail OAuth files (defaults shown; only set if you move them).
# GMAIL_CREDENTIALS_PATH=credentials.json
# GMAIL_TOKEN_PATH=token.json
